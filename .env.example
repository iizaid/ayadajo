# Ayadajo environment variables
# Names only. Do not commit real values.

# Supabase public client configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server-only configuration
# Service role bypasses RLS. Use only in Super Admin and trusted job paths.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase database URL for SQL migrations only
SUPABASE_DB_URL=

# Transactional email
RESEND_API_KEY=

# Application
APP_URL=

# Vercel Cron protection
CRON_SECRET=

# Observability
SENTRY_DSN=

# Super Admin bootstrap
SUPER_ADMIN_BOOTSTRAP_EMAIL=
SUPER_ADMIN_BOOTSTRAP_PASSWORD=
SUPER_ADMIN_BOOTSTRAP_NAME=
SUPER_ADMIN_BOOTSTRAP_2FA_REQUIRED=
